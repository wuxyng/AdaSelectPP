+    @staticmethod
+    def _normalize_sql_for_timeout_signature(sql: str) -> str:
+        """Return a cheap template-like SQL shape used only for timeout diagnostics.
+
+        This deliberately avoids a full SQL parser: constants are erased and
+        whitespace is collapsed so repeated instances of the same template map
+        to the same signature, while different workload phases usually diverge.
+        """
+        try:
+            text = str(sql or "").lower()
+            text = re.sub(r"'([^']|'')*'", "?", text)
+            text = re.sub(r'"([^"\\]|\\.)*"', "?", text)
+            text = re.sub(r"\b\d+(?:\.\d+)?\b", "?", text)
+            text = re.sub(r"\s+", " ", text).strip()
+            return text[:512]
+        except Exception:
+            return str(sql or "")[:512]
+
+    def _workload_timeout_signature(self, workload: Optional[List[str]]) -> Set[str]:
+        if not workload:
+            return set()
+        sig: Set[str] = set()
+        for q in workload:
+            norm = self._normalize_sql_for_timeout_signature(q)
+            if norm:
+                sig.add(norm)
+        return sig
+
+    @staticmethod
+    def _signature_jaccard(a: Set[str], b: Set[str]) -> Optional[float]:
+        if not a or not b:
+            return None
+        return float(len(a & b)) / float(max(1, len(a | b)))
+
