     def _choose_config(self, old_conf: Set[IndexKey]) -> List[IndexKey]:
+        """Dispatch to the configured configuration-update policy."""
+        policy = str(getattr(self, "choose_policy", "retain_swap") or "retain_swap").lower()
+        if policy in {"topk_beta", "topk-beta", "topk", "beta", "legacy", "lite"}:
+            return self._choose_config_topk_beta(old_conf)
+        if policy not in {"retain_swap", "retainswap", "swap", "local"}:
+            logger.warning("Unknown choose_policy=%s; falling back to retain_swap", policy)
+        return self._choose_config_retain_swap(old_conf)
+
+    @staticmethod
+    def _safe_ratio(new_value: float, old_value: float) -> float:
+        eps = 1e-9
+        if old_value > eps and new_value > eps:
+            return new_value / old_value
+        if old_value < -eps and new_value < -eps:
+            return abs(old_value) / abs(new_value) if abs(new_value) > eps else float("-inf")
+        if old_value < -eps and new_value > eps:
+            return float("inf")
+        if abs(old_value) <= eps and new_value > eps:
+            return float("inf")
+        return float("-inf")
+
+    def _retainswap_stale_score(self, key: IndexKey) -> float:
+        """Normalize incumbent age into [0, 1] for retain/swap scoring."""
+        state = getattr(self, "installed_index_state", {}) or {}
+        st = state.get(key) if isinstance(state, dict) else None
+        if st is None:
+            return 1.0
+        try:
+            last = int(getattr(st, "last_selected_round", -1))
+            if last < 0:
+                return 1.0
+            horizon = max(1, int(getattr(self, "retain_swap_stale_horizon", 10)))
+            age = max(0, int(getattr(self, "workload_count", 0)) - last)
+            return max(0.0, min(1.0, float(age) / float(horizon)))
+        except Exception:
+            return 1.0
+
+    def _normalize_positive_map(self, values: Dict[IndexKey, float], keys: Set[IndexKey]) -> Dict[IndexKey, float]:
+        """Max-normalize non-negative diagnostics such as risk/support into [0, 1]."""
+        if not keys:
+            return {}
+        max_v = 0.0
+        out: Dict[IndexKey, float] = {}
+        for k in keys:
+            try:
+                v = max(0.0, float(values.get(k, 0.0) or 0.0))
+            except Exception:
+                v = 0.0
+            out[k] = v
+            max_v = max(max_v, v)
+        if max_v <= 1e-9:
+            return {k: 0.0 for k in keys}
+        return {k: min(1.0, v / max_v) for k, v in out.items()}
+
+    def _choose_config_retain_swap(self, old_conf: Set[IndexKey]) -> List[IndexKey]:
+        """
+        Phase 1.5 local configuration update.
+
+        Visible action space:
+            visible_action_set = appearing_curr ∪ old_conf
+
+        `keep_visible` is not allowed to expand the action space. It only supplies
+        a retention bonus to old incumbents that were surfaced through U_keep.
+        The method starts from old_conf and admits newcomers by filling open slots
+        or by swapping them against the weakest retained incumbent when:
+
+            A(newcomer) - R(incumbent) > retain_swap_delta
+        """
+        old_canon: Set[IndexKey] = {_canon(k) for k in old_conf}
+        appearing_curr: Set[IndexKey] = set(getattr(self, "_last_appearing_curr_set", set()) or set())
+        keep_visible: Set[IndexKey] = set(getattr(self, "_last_keep_visible_set", set()) or set())
+
+        if keep_visible and not keep_visible.issubset(old_canon):
+            raise RuntimeError(
+                f"keep_visible must be a subset of old_conf; stray={sorted(keep_visible - old_canon)}"
+            )
+        if appearing_curr.intersection(keep_visible):
+            raise RuntimeError(
+                f"appearing_curr and keep_visible must be disjoint; overlap={sorted(appearing_curr & keep_visible)}"
+            )
+
+        max_k = max(0, int(getattr(self, "max_num", 10)))
+        visible_keys: Set[IndexKey] = set(appearing_curr).union(old_canon)
+        self._last_visible_action_set = set(visible_keys)
+
+        # Empty visible space: clear diagnostics and return no recommendation.
+        if not visible_keys or max_k <= 0:
+            final_conf: Set[IndexKey] = set()
+            self._last_candidate_conf = set(final_conf)
+            self._last_final_conf = set(final_conf)
+            self._last_net_benefit_map = {}
+            self._last_retention_score_map = {}
+            self._last_admission_score_map = {}
+            self._last_swap_partner_map = {}
+            self._last_blocked_swap_map = {}
+            self._last_decision_stats = {
+                "policy": "retain_swap",
+                "old_benefit": 0.0,
+                "new_benefit": 0.0,
+                "ratio": float("-inf"),
+                "beta": float(getattr(self, "beta", 0.0)),
+                "delta_swap": float(getattr(self, "retain_swap_delta", 0.05)),
+                "timeout_state": str(getattr(self, "_timeout_state", "normal")),
+                "timeout_recovery_action": str(getattr(self, "_timeout_recovery_action", "")),
+                "timeout_workload_similarity": getattr(self, "_timeout_workload_similarity", None),
+                "timeout_bad_old_count": int(len(getattr(self, "_timeout_bad_old_conf", set()) or set())),
+                "timeout_drop_count": 0,
+                "visible_curr": float(len(appearing_curr)),
+                "visible_keep": float(len(keep_visible)),
+                "visible_old_conf": float(len(old_canon)),
+                "visible_total": float(len(visible_keys)),
+                "retained_old_count": 0,
+                "admitted_new_count": 0,
+                "dropped_old_count": len(old_canon),
+                "swap_count": 0,
+                "blocked_swap_count": 0,
+            }
+            return []
+
+        raw_benefit = {k: float(self.columns_benefit.get(k, 0.0)) for k in visible_keys}
+        benefit_norm = self._minmax_norm(raw_benefit)
+
+        raw_struct = {k: float((getattr(self, "_last_wdcg_score_map", {}) or {}).get(k, 0.0)) for k in visible_keys}
+        structural_norm = self._minmax_norm(raw_struct)
+
+        support_raw = {k: float((getattr(self, "_last_support_count_map", {}) or {}).get(k, 0.0)) for k in visible_keys}
+        support_norm = self._normalize_positive_map(support_raw, visible_keys)
+
+        risk_raw = {k: abs(float((getattr(self, "idx_abs_error_smooth", {}) or {}).get(k, 0.0) or 0.0)) for k in visible_keys}
+        risk_norm = self._normalize_positive_map(risk_raw, visible_keys)
+
+        timeout_state = str(getattr(self, "_timeout_state", "normal") or "normal")
+        timeout_active = timeout_state != "normal"
+        timeout_bad_old: Set[IndexKey] = set(getattr(self, "_timeout_bad_old_conf", set()) or set())
+        timeout_retain_penalty_w = float(getattr(self, "timeout_retain_penalty", 0.75)) if timeout_active else 0.0
+        timeout_disable_keep_bonus = bool(getattr(self, "timeout_disable_keep_bonus", True)) and timeout_active
+        timeout_delta_scale = float(getattr(self, "timeout_delta_scale", 0.50)) if timeout_active else 1.0
+        timeout_delta_scale = max(0.0, min(1.0, timeout_delta_scale))
+        timeout_drop_unsupported_old = bool(getattr(self, "timeout_drop_unsupported_old", True)) and timeout_active
+        timeout_drop_floor = float(getattr(self, "timeout_drop_floor", 0.50))
+
+        delta_swap = float(getattr(self, "retain_swap_delta", 0.05)) * timeout_delta_scale
+        admit_floor = float(getattr(self, "retain_swap_admit_floor", 0.0))
+        keep_bonus_w = float(getattr(self, "retain_swap_keep_bonus", 0.20))
+        curr_bonus_w = float(getattr(self, "retain_swap_curr_bonus", 0.15))
+        structural_w = float(getattr(self, "retain_swap_structural_weight", 0.25))
+        support_w = float(getattr(self, "retain_swap_support_weight", 0.10))
+        stale_w = float(getattr(self, "retain_swap_stale_weight", 0.15))
+        risk_w = float(getattr(self, "retain_swap_risk_weight", 0.10))
+        maintenance_w = float(getattr(self, "retain_swap_maintenance_weight", 0.05))
+        create_w = float(getattr(self, "retain_swap_create_cost_weight", 1.00))
+        max_blocked_log = max(0, int(getattr(self, "retain_swap_max_blocked_log", 20)))
+
+        retention_scores: Dict[IndexKey, float] = {}
+        admission_scores: Dict[IndexKey, float] = {}
+
+        for key in old_canon:
+            current_support_bonus = 0.0
+            if key in appearing_curr:
+                current_support_bonus = (
+                    curr_bonus_w
+                    + structural_w * float(structural_norm.get(key, 0.0))
+                    + support_w * float(support_norm.get(key, 0.0))
+                )
+            keep_bonus = keep_bonus_w if key in keep_visible else 0.0
+            if timeout_disable_keep_bonus and key in timeout_bad_old:
+                keep_bonus = 0.0
+            stale_penalty = stale_w * self._retainswap_stale_score(key)
+            risk_penalty = risk_w * float(risk_norm.get(key, 0.0))
+            maintenance_penalty = maintenance_w * float(self._creation_cost(key))
+            timeout_penalty = timeout_retain_penalty_w if key in timeout_bad_old else 0.0
+            retention_scores[key] = (
+                float(benefit_norm.get(key, 0.0))
+                + keep_bonus
+                + current_support_bonus
+                - stale_penalty
+                - risk_penalty
+                - maintenance_penalty
+                - timeout_penalty
+            )
+
+        newcomers: Set[IndexKey] = set(appearing_curr).difference(old_canon)
+        for key in newcomers:
+            create_penalty = create_w * float(self._creation_cost(key))
+            risk_penalty = risk_w * float(risk_norm.get(key, 0.0))
+            admission_scores[key] = (
+                float(benefit_norm.get(key, 0.0))
+                + curr_bonus_w
+                + structural_w * float(structural_norm.get(key, 0.0))
+                + support_w * float(support_norm.get(key, 0.0))
+                - create_penalty
+                - risk_penalty
+            )
+
+        # Expose per-index local scores to traces. Old keys carry R, newcomers carry A.
+        action_scores: Dict[IndexKey, float] = {}
+        action_scores.update(retention_scores)
+        action_scores.update(admission_scores)
+        self._last_retention_score_map = dict(retention_scores)
+        self._last_admission_score_map = dict(admission_scores)
