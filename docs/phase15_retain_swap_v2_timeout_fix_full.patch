index 0000000..2647f71
--- /dev/null
+++ b/scripts/run_phase15_retainswap_firstpass.sh
@@ -0,0 +1,64 @@
+#!/usr/bin/env bash
+set -Eeuo pipefail
+
+cd "$(dirname "$0")/.."
+
+# Phase 1.5 first-pass matrix:
+#   - E1 slice: CurrOnly vs CurrKeep under retain/swap
+#   - E2 slice: TopK/Beta vs RetainSwap under CurrKeep
+# Workloads chosen from the handoff: tpchs_shifting, tpchs_noisy, job_random.
+
+CFG_DIR="adasel/config"
+RUN_ROOT="runs_phase15_retainswap_firstpass"
+mkdir -p "${RUN_ROOT}"
+
+VARIANT_CFGS=(
+  "curr_only_retain_swap:${CFG_DIR}/adaselect_g0_phase1_curr_only.json"
+  "curr_keep_topk_beta:${CFG_DIR}/adaselect_g0_phase1_topk_beta.json"
+  "curr_keep_retain_swap:${CFG_DIR}/adaselect_g0_phase1_retain_swap.json"
+)
+
+WORKLOAD_FILTERS=(
+  "tpchs shifting"
+  "tpchs noisy"
+  "job random"
+)
+
+for entry in "${VARIANT_CFGS[@]}"; do
+  variant="${entry%%:*}"
+  cfg="${entry#*:}"
+  [[ -f "${cfg}" ]] || { echo "missing cfg: ${cfg}" >&2; exit 2; }
+
+  echo "===== Phase1.5 variant=${variant} cfg=${cfg} ====="
+  cp "${cfg}" "${CFG_DIR}/adaselect.json"
+
+  stamp="$(mktemp)"
+  touch "${stamp}"
+
+  for filt in "${WORKLOAD_FILTERS[@]}"; do
+    echo "===== variant=${variant} case=${filt} ====="
+    TRACE=1 \
+    LAM_POLICIES=adaptive \
+    WDCG_VALUES=1 \
+    MIN_WIDTH=1 \
+    MAX_WIDTH=2 \
+    CASES_FILTER="${filt}" \
+    bash scripts/sweep_adaselect_lambda_wdcg.sh
+  done
+
+  out_dir="${RUN_ROOT}/${variant}"
+  mkdir -p "${out_dir}/log" "${out_dir}/analysis"
+  find log -maxdepth 1 -type f -newer "${stamp}" -exec mv -t "${out_dir}/log" {} + || true
+  if [[ -d analysis ]]; then
