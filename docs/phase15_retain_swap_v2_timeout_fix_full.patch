diff --git a/adaselect_pp/tests/test_retain_swap_choose_config.py b/adaselect_pp/tests/test_retain_swap_choose_config.py
new file mode 100644
index 0000000..84fee57
--- /dev/null
+++ b/adaselect_pp/tests/test_retain_swap_choose_config.py
@@ -0,0 +1,270 @@
+from types import SimpleNamespace
+
+
+from adasel.ada_select import AdaSelect
+from adaselect_pp.core.types import InstalledIndexState
+
+
+IndexKey = tuple[str, tuple[str, ...]]
+
+
+def _idx(col: str) -> IndexKey:
+    return ("t", (col,))
+
+
+def _state(key: IndexKey, *, last: int = 5) -> InstalledIndexState:
+    return InstalledIndexState(
+        key=key,
+        is_merge=False,
+        base_key=key,
+        family="BASE",
+        width=len(key[1]),
+        installed_round=0,
+        last_selected_round=last,
+    )
+
+
+def _mk_tuner(*, max_num: int = 1, costs=None) -> AdaSelect:
+    t = AdaSelect.__new__(AdaSelect)
+    t.max_num = max_num
+    t.beta = 1.1
+    t.workload_count = 5
+    t.choose_policy = "retain_swap"
+    t.timeout = 30_000
+    t.timeout_policy = "replan"
+    t.timeout_reset_after = 2
+    t.timeout_shift_similarity_threshold = 0.35
+    t.timeout_force_full_budget = True
+    t.timeout_retain_penalty = 0.75
+    t.timeout_disable_keep_bonus = True
+    t.timeout_delta_scale = 0.50
+    t.timeout_drop_unsupported_old = True
+    t.timeout_drop_floor = 0.50
+    t.consecutive_timeouts = 0
+    t.last_stable_config = set()
+    t._timeout_state = "normal"
+    t._timeout_recovery_action = ""
+    t._timeout_workload_similarity = None
+    t._timeout_bad_old_conf = set()
+    t._timeout_force_full_budget_once = False
+    t._last_stable_workload_sig = set()
+    t._prev_workload_sig = set()
+
+    t.retain_swap_delta = 0.05
+    t.retain_swap_admit_floor = 0.0
+    t.retain_swap_keep_bonus = 0.20
+    t.retain_swap_curr_bonus = 0.15
+    t.retain_swap_structural_weight = 0.25
+    t.retain_swap_support_weight = 0.10
+    t.retain_swap_stale_weight = 0.15
+    t.retain_swap_risk_weight = 0.10
+    t.retain_swap_maintenance_weight = 0.05
+    t.retain_swap_create_cost_weight = 1.0
+    t.retain_swap_stale_horizon = 10
+    t.retain_swap_max_blocked_log = 20
+
+    t.columns_benefit = {}
+    t.idx_abs_error_smooth = {}
+    t.idx_seen_cnt = {}
+    t.cost_model = SimpleNamespace(index_costs=dict(costs or {}))
+    t.installed_index_state = {}
+
+    t._m_stats = {
+        "what_if_calls": 0,
+        "candidate_count": 0,
+        "evaluated_count": 0,
+        "reconf_add": 0,
+        "reconf_drop": 0,
+        "trans_create": 0.0,
+        "trans_drop": 0.0,
+    }
+    t._last_evaluated_set = set()
+    t._last_eval_order = []
+    t._last_appearing_curr_set = set()
+    t._last_keep_visible_set = set()
+    t._last_visible_action_set = set()
+    t._last_candidate_conf = set()
+    t._last_final_conf = set()
+    t._last_net_benefit_map = {}
+    t._last_obs_delta_map = {}
+    t._last_obs_src_map = {}
+    t._last_support_count_map = {}
+    t._last_main_target_set = set()
+    t._last_corr_target_set = set()
+    t._last_index_meta_map = {}
+    t._last_retention_score_map = {}
+    t._last_admission_score_map = {}
+    t._last_swap_partner_map = {}
+    t._last_blocked_swap_map = {}
+    t._last_decision_stats = {}
+    t._last_wdcg_score_map = {}
+    t._last_wdcg_stats = {}
+    t._last_deadzone_stats = {"deadzone_old_support": 0, "deadzone_blocked": 0}
+    return t
+
+
+def test_retain_swap_swaps_when_admission_beats_retention_delta():
+    old = _idx("a")
+    new = _idx("b")
+    t = _mk_tuner(max_num=1, costs={old[1]: 0.0, new[1]: 0.0})
+    t.columns_benefit = {old: 0.1, new: 10.0}
+    t._last_appearing_curr_set = {new}
+    t._last_wdcg_score_map = {new: 1.0, old: 0.0}
+    t._last_support_count_map = {new: 3}
+    t.installed_index_state = {old: _state(old)}
+
+    before_state = dict(t.installed_index_state)
+    selected = set(t._choose_config({old}))
+
+    assert selected == {new}
+    assert t.installed_index_state == before_state  # state is refreshed only after final new_conf externally
+    assert t._last_decision_stats["swap_count"] == 1
+    assert t._last_decision_stats["admitted_new"] == [new]
+    assert t._last_decision_stats["dropped_old"] == [old]
+
+    t._refresh_installed_index_state(selected)
+    assert new in t.installed_index_state
+    assert old not in t.installed_index_state
+
+
+def test_keep_visible_bonus_blocks_marginal_newcomer():
+    old = _idx("a")
+    new = _idx("b")
+    t = _mk_tuner(max_num=1, costs={old[1]: 0.0, new[1]: 0.20})
+    t.columns_benefit = {old: 0.60, new: 0.61}
+    t._last_appearing_curr_set = {new}
+    t._last_keep_visible_set = {old}
+    t.installed_index_state = {old: _state(old)}
+
+    selected = set(t._choose_config({old}))
+
+    assert selected == {old}
+    assert t._last_decision_stats["retained_old"] == [old]
+    assert t._last_decision_stats["admitted_new"] == []
+    assert t._last_decision_stats["blocked_swap_count"] == 1
+    assert t._last_retention_score_map[old] > t._last_admission_score_map[new]
+
+
+def test_keep_visible_cannot_expand_action_space():
+    old = _idx("a")
+    stray_keep = _idx("k")
+    t = _mk_tuner(max_num=1)
+    t._last_appearing_curr_set = set()
+    t._last_keep_visible_set = {stray_keep}
+
+    raised = False
+    try:
+        t._choose_config({old})
+    except RuntimeError as exc:
+        raised = True
+        assert "keep_visible must be a subset" in str(exc)
+    assert raised
+
+
+def test_appearing_curr_and_keep_visible_must_be_disjoint():
+    old = _idx("a")
+    t = _mk_tuner(max_num=1)
+    t._last_appearing_curr_set = {old}
+    t._last_keep_visible_set = {old}
+
+    raised = False
+    try:
+        t._choose_config({old})
+    except RuntimeError as exc:
+        raised = True
+        assert "appearing_curr and keep_visible" in str(exc)
+    assert raised
+
+
+def test_cold_start_seeds_from_visible_current_candidates_even_when_scores_are_zero_after_cost():
+    a = _idx("a")
+    b = _idx("b")
+    t = _mk_tuner(max_num=2)  # default create cost is 1.0; local A can be negative.
+    t.columns_benefit = {a: 0.0, b: 0.0}
+    t._last_appearing_curr_set = {a, b}
+
+    selected = set(t._choose_config(set()))
+
+    assert selected == {a, b}
+    assert t._last_decision_stats["policy"] == "retain_swap"
+    assert t._last_decision_stats["admitted_new_count"] == 2
+    assert t._last_visible_action_set == {a, b}
+
+
+
+def test_timeout_recovery_replans_current_workload_without_rollback_or_physical_reset():
+    old = _idx("old_phase")
+    stable = _idx("stable_old_phase")
+    t = _mk_tuner(max_num=1)
+    t.timeout = 100
+    t.workload_count = 5
+    t.last_stable_config = {stable}
+    t._last_stable_workload_sig = t._workload_timeout_signature([
+        "select * from orders where o_orderstatus = 'F'"
+    ])
+
+    class DB2:
+        dropped = False
+        def drop_all_indexes(self):  # should never be called by timeout policy
+            self.dropped = True
+
+    t.db_con2 = DB2()
+    old_conf = {old}
+
+    forced = t._handle_timeout_policy(
+        [100],
+        old_conf,
+        ["select * from lineitem where l_shipdate > date '1998-01-01'"],
+    )
+
+    assert forced is None
+    assert old_conf == {old}
+    assert t.db_con2.dropped is False
+    assert t._timeout_state == "timeout_phase_shift"
+    assert t._timeout_recovery_action == "replan_current_workload"
+    assert t._timeout_bad_old_conf == {old}
+    assert t._timeout_force_full_budget_once is True
+
+
+def test_timeout_penalty_disables_keep_bonus_and_prefers_current_phase_newcomer():
+    old = _idx("old_phase")
+    new = _idx("new_phase")
+    t = _mk_tuner(max_num=1, costs={old[1]: 0.0, new[1]: 0.0})
+    t.columns_benefit = {old: 10.0, new: 9.0}
+    t._last_appearing_curr_set = {new}
+    t._last_keep_visible_set = {old}
+    t._last_wdcg_score_map = {new: 1.0, old: 0.0}
+    t._last_support_count_map = {new: 3}
+    t.installed_index_state = {old: _state(old)}
+    t._timeout_state = "timeout_phase_shift"
+    t._timeout_recovery_action = "replan_current_workload"
+    t._timeout_bad_old_conf = {old}
+
+    selected = set(t._choose_config({old}))
+
+    assert selected == {new}
+    assert t._last_decision_stats["timeout_state"] == "timeout_phase_shift"
+    assert t._last_decision_stats["timeout_bad_old_count"] == 1
+    assert t._last_decision_stats["timeout_drop_count"] == 1
+    assert t._last_decision_stats["swap_count"] == 0
+    assert t._last_decision_stats["admitted_new"] == [new]
+    assert t._last_decision_stats["dropped_old"] == [old]
+    assert t._last_retention_score_map[old] < t._last_admission_score_map[new]
+
+
+
+def test_timeout_recovery_can_drop_unsupported_old_without_replacement():
+    old = _idx("old_phase")
+    t = _mk_tuner(max_num=1, costs={old[1]: 0.0})
+    t.columns_benefit = {old: 10.0}
+    t._last_appearing_curr_set = set()
+    t._last_keep_visible_set = {old}
+    t.installed_index_state = {old: _state(old)}
+    t._timeout_state = "timeout_phase_shift"
+    t._timeout_bad_old_conf = {old}
+
+    selected = set(t._choose_config({old}))
+
+    assert selected == set()
+    assert t._last_decision_stats["timeout_drop_count"] == 1
+    assert t._last_decision_stats["dropped_old"] == [old]
